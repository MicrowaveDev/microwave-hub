{
  "name": "microwave-hub",
  "private": true,
  "scripts": {
    "pull": "git pull --rebase && git submodule update --init --recursive",
    "setup": "git submodule update --init --recursive",
    "dev:viewer": "yarn --cwd agent-viewer dev",
    "mushroom:dev": "npm --prefix mushroom-master run game:start",
    "microwave-girls:dev": "yarn --cwd microwave-girls start",
    "microwave-travel:dev": "npm --prefix microwave-travel run dev",
    "status:all": "bash bash/status-all.sh",
    "repo:context": "bash bash/repo-context.sh",
    "task:context": "bash bash/task-context.sh",
    "route:agent": "node bash/resolve-agent-route.mjs",
    "validate:agent-route": "node bash/validate-agent-route-trace.mjs",
    "verify:instructions": "node bash/verify-instruction-contracts.mjs",
    "capture:command": "bash bash/capture-command-output.sh",
    "cleanup:command-output": "node bash/cleanup-agent-command-output.mjs",
    "read:command-output": "node bash/read-agent-command-output.mjs",
    "test:command-capture": "node bash/test-capture-command-output.mjs",
    "flow:checkpoint": "node bash/agent-flow-checkpoint.mjs",
    "flow:packet": "node bash/agent-work-packet.mjs",
    "test:flow-state": "node --test bash/test-agent-flow-state.mjs",
    "compare:agent-context-strategies": "node bash/compare-agent-context-strategies.mjs",
    "test:context-strategies": "node --test bash/test-context-strategy-comparison.mjs",
    "worktree:safety": "bash bash/check-worktree-safety.sh",
    "find:repos": "bash bash/find-in-repos.sh",
    "pending:prs": "bash bash/pending-prs.sh",
    "prepare:pointers": "bash bash/prepare-pointer-updates.sh",
    "gh:safe": "bash bash/gh-safe.sh",
    "github:body:check": "bash bash/gh-safe.sh check",
    "shrink:screenshots": "bash bash/shrink-screenshots.sh",
    "verify:backpack-core": "bash bash/verify-backpack-core-consumers.sh",
    "verify:helpers": "bash bash/verify-helpers.sh"
  }
}
