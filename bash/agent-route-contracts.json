{
  "schemaVersion": 1,
  "instructionByteLimit": 16384,
  "routes": [
    {
      "id": "production-image-description-queue",
      "triggers": [
        "production image-description queue",
        "image-description queue",
        "image description subagents"
      ],
      "repo": "artist-helper",
      "firstCommand": "npm run task:context -- artist-helper",
      "forbiddenBeforeRoute": [
        "portable-agent-instructions.md",
        "SUBMODULES.md",
        "package.json",
        "npm run find:repos"
      ]
    },
    {
      "id": "production-threads-suggestions-queue",
      "triggers": [
        "production Threads post suggestions queue",
        "Threads post suggestions queue",
        "Run the production Threads post suggestions queue for this week; follow the repo queue instructions, open the local review page, and hand off QA counts."
      ],
      "repo": "artist-helper",
      "firstCommand": "npm run task:context -- artist-helper",
      "forbiddenBeforeRoute": [
        "portable-agent-instructions.md",
        "SUBMODULES.md",
        "README.md",
        "package.json",
        "npm run find:repos"
      ]
    }
  ]
}
